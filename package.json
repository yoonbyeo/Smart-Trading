{
  "name": "stock-investment-website",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "npm run build:client",
    "build:client": "npm install --prefix client --legacy-peer-deps && npm run build --prefix client",
    "start": "NODE_ENV=production node server/src/index.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "yahoo-finance2": "^2.11.11"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
